{
    "redirects": [
        {
            "source": "/web/:path*",
            "destination": "/:path*",
            "permanent": true
        },
        {
            "source": "/web",
            "destination": "/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}