rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Solo permitir lectura/escritura a usuarios autenticados
    // Idealmente, acá verificaríamos el workspace, pero como MVP
    // restringimos a usuarios con sesión activa.
    match /workspaces/{workspaceId}/calls/{callId}/{path=**} {
      allow read, write: if request.auth != null; 
    }
    
    // Rechazar todo el resto por default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
